# =============================================================================
# Oncall Triage Agent - Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# -- App --
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
METRIC_WINDOW_MINUTES=10
MAX_LOG_RESULTS=200

# -- Datadog --
DD_API_KEY=62b650c0a7011b686330e04166110a12842800b3
DD_APP_KEY=oncall-triage-app-key
DD_SITE=datadoghq.com
# Other sites: us3.datadoghq.com, us5.datadoghq.com, datadoghq.eu, ddog-gov.com

# -- Elasticsearch / Kibana --
ES_HOSTS=https://your-es-cluster:9200
ES_API_KEY=your-elasticsearch-api-key
# Or use basic auth instead of API key:
# ES_USERNAME=elastic
# ES_PASSWORD=your-password
ES_INDEX_PATTERN=app-logs-*
ES_KIBANA_BASE_URL=https://kibana.stage.pharmeasy.in

# -- Google Chat --
GCHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/SPACE_ID/messages?key=KEY&token=TOKEN

# -- GitHub --
GITHUB_TOKEN=ghp_your-personal-access-token
GITHUB_ORG=your-github-org
GITHUB_DEFAULT_REPOS=repo1,repo2,repo3
